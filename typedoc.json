{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": ["src/core", "src/cli"],
    "entryPointStrategy": "expand",
    "out": "docs",
    "name": "jseeqret",
    "readme": "README.md",
    "includeVersion": true,
    "excludePrivate": true,
    "excludeInternal": true,
    "sort": ["source-order"],
    "jsDocCompatibility": {
        "exampleTag": true,
        "defaultTag": true,
        "inheritDocTag": true,
        "ignoreUnescapedBraces": true
    }
}
