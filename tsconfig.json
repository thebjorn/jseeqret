{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": ["src/core/**/*.js", "src/cli/**/*.js"]
}
