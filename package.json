{
  "name": "jseeqret",
  "version": "2.1.0",
  "type": "module",
  "description": "Secure secrets manager - JavaScript/Electron/Svelte5 port of seeqret",
  "author": "thebjorn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebjorn/jseeqret"
  },
  "bugs": "https://github.com/thebjorn/jseeqret/issues",
  "homepage": "https://github.com/thebjorn/jseeqret#readme",
  "keywords": [
    "secrets",
    "secrets-manager",
    "encryption",
    "vault",
    "fernet",
    "nacl",
    "cli",
    "electron"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.11.0",
  "main": "./out/main/index.js",
  "exports": {
    ".": "./src/core/api.js",
    "./core": "./src/core/index.js"
  },
  "bin": {
    "jseeqret": "./src/cli/index.js"
  },
  "files": [
    "src/core",
    "src/cli",
    "README.md"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win --publish always",
    "dist:nsis": "electron-vite build && electron-builder --win nsis",
    "cli": "node ./src/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "node bench/get-benchmark.js",
    "docs:build": "typedoc"
  },
  "build": {
    "appId": "com.jseeqret.app",
    "productName": "jseeqret",
    "copyright": "Copyright © 2024-2026 jseeqret contributors",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "sign": "./sign.js"
      }
    },
    "nsis": {
      "artifactName": "${name}-setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "jseeqret"
    },
    "publish": {
      "provider": "github",
      "owner": "thebjorn",
      "repo": "jseeqret"
    }
  },
  "dependencies": {
    "@slack/web-api": "^7.16.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "electron-updater": "^6.8.9",
    "sql.js": "^1.14.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "svelte": "^5.56.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "form-data@<4.0.6": "^4.0.6",
      "undici@<6.27.0": "^6.27.0"
    }
  }
}
