{
  "name": "jseeqret",
  "version": "0.5.7",
  "type": "module",
  "description": "Secure secrets manager - JavaScript/Electron/Svelte5 port of seeqret",
  "author": "thebjorn",
  "main": "./out/main/index.js",
  "exports": {
    ".": "./src/core/api.js",
    "./core": "./src/core/index.js"
  },
  "bin": {
    "jseeqret": "./src/cli/index.js"
  },
  "files": [
    "src/core",
    "src/cli",
    "README.md"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win --publish always",
    "dist:nsis": "electron-vite build && electron-builder --win nsis",
    "dist:portable": "electron-vite build && electron-builder --win portable",
    "cli": "node ./src/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "node bench/get-benchmark.js",
    "docs": "jsdoc -c jsdoc.config.json"
  },
  "build": {
    "appId": "com.jseeqret.app",
    "productName": "jseeqret",
    "copyright": "Copyright © 2024-2026 jseeqret contributors",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "jseeqret"
    },
    "publish": {
      "provider": "github",
      "owner": "thebjorn",
      "repo": "jseeqret"
    }
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "electron-updater": "^6.8.3",
    "sql.js": "^1.11.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdoc": "^4.0.5",
    "svelte": "^5.53.12",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
